# Keep real API keys out of git.
# Add real values in local .env files or deployment environment variables.
# 既定ではサンプルデータ / 楽天APIモックで動作するため、実API用の値は不要です。
# `VITE_` で始まる値はブラウザに露出するため、リアルシークレットは絶対に入れないでください。

VITE_APP_NAME=Coconala Tool
VITE_ENABLE_SAMPLE_DATA=true

# Server-side only secrets (for Cloudflare Pages Functions / Workers / Next.js API routes).
# Do NOT expose these values to the browser bundle (no VITE_ prefix).
#
# SERVER_RAKUTEN_APP_ID を設定すると、Pages Function `/api/rakuten` 経由で
# 楽天市場 商品検索API の「実データ」に切り替わります（ソースラベル: 公式API取得）。
# 未設定の場合は自動で公式API想定モックにフォールバックします（アプリは落ちません）。
# Cloudflare Pages では Settings > Environment variables に（暗号化で）設定してください。
SERVER_RAKUTEN_APP_ID=

# 将来の拡張用（現状は未使用。設定しても挙動は変わりません）。
SERVER_EBAY_CLIENT_ID=
SERVER_EBAY_CLIENT_SECRET=
SERVER_YAHOO_SHOPPING_APP_ID=
SERVER_BRAVE_SEARCH_API_KEY=
SERVER_EXCHANGE_API_KEY=
